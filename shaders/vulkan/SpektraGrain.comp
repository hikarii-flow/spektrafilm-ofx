vec4 blurMicroX(uvec2 gid) {
  const float sigma = max(f(kFrameGrainMicroStructureScale), 0.0) / max(f(kFrameFilmPixelSizeUm), 1.0e-6);
  if (u(kFrameIntGrainSublayersEnabled) == 0u || sigma <= 0.4) {
    return sampleMicroA(int(gid.x), int(gid.y));
  }
  if (u(kFrameIntGrainBlurRecurrence) != 0u) {
    const GaussianBlurInfo info = makeGaussianBlurInfo(sigma, 64);
    const int x = int(gid.x);
    const int y = int(gid.y);
    vec4 value = sampleMicroA(x, y);
    float weight = info.firstWeight;
    float ratio = info.firstRatio;
    for (int offset = 1; offset <= int(info.radius); ++offset) {
      value += weight * (sampleMicroA(x - offset, y) + sampleMicroA(x + offset, y));
      weight *= ratio;
      ratio *= info.ratioStep;
    }
    return value * info.invWeightSum;
  }
  const int radius = min(int(ceil(3.0 * sigma)), 64);
