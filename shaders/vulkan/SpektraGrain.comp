void main() {
  const uvec3 activeGid3 = gl_GlobalInvocationID.xyz;
  const uint activeWidth = params.activeWidth == 0u ? params.width : params.activeWidth;
  const uint activeHeight = params.activeHeight == 0u ? params.height : params.activeHeight;
  if (activeGid3.x >= activeWidth || activeGid3.y >= activeHeight) {
    return;
  }
  const uvec3 gid3 = uvec3(activeGid3.xy + uvec2(params.activeOriginX, params.activeOriginY), activeGid3.z);
  if (gid3.x >= params.width || gid3.y >= params.height) {
    return;
  }
  const uint index = gid3.y * params.width + gid3.x;

  const uint baseSeed = u(kFrameIntGrainSeed) ^ u(kFrameIntGrainFrameSeed);
  if (params.operation == kOpPreview) {
    const vec4 source = loadSourcePixel(index);
    const vec3 grained = previewGrainDensity(source.rgb, outputPixelFilmUm(gid3.xy), baseSeed);
    storeDestinationPixel(index, vec4(applyGrainControls(source.rgb, grained), source.a));
    return;
  }

  if (params.operation == kOpProductionLayers) {
    if (gid3.z >= 9u) {
      return;
    }
    const uint component = gid3.z;
    const uint layer = component / 3u;
    const uint channel = component - layer * 3u;
    grainLayerA[index * 9u + component] = productionLayerParticleDensity(
      loadSourcePixel(index).rgb,
      layer,
      channel,
      outputPixelFilmUm(gid3.xy),
      baseSeed
    );
    return;
  }

  if (params.operation == kOpSynthesisLayers) {
    if (gid3.z >= 9u) {
      return;
    }
    grainLayerA[index * 9u + gid3.z] = grainSynthesisLayerFromDensity(gid3, baseSeed);
    return;
  }

  if (params.operation == kOpLayerBlurX) {
    if (gid3.z >= 9u) {
      return;
    }
    grainLayerB[index * 9u + gid3.z] = layerBlurX(gid3, true);
    return;
  }

  if (params.operation == kOpLayerBlurY) {
    if (gid3.z >= 9u) {
      return;
    }
    grainLayerA[index * 9u + gid3.z] = layerBlurY(gid3, false);
    return;
  }

  if (params.operation == kOpMicroSource) {
    const float sigma = max(f(kFrameGrainMicroStructureSigmaPx), 0.0);
    if (u(kFrameIntGrainSublayersEnabled) == 0u || sigma <= 0.05 || f(kFrameGrainMicroStructureScale) <= 0.0) {
      storeMicroAPixel(index, vec4(1.0));
      return;
    }
    const vec2 filmUm = outputPixelFilmUm(gid3.xy);
    const uint seed = filmCellSeed(
      filmUm,
      max(f(kFrameGrainMicroStructureScale), 1.0e-4),
      baseSeed ^ 0x23d3c1f1u ^ 0xa349b329u
    );
    const float logSigma = sqrt(log(1.0 + sigma * sigma));
    const float logMean = -0.5 * logSigma * logSigma;
    storeMicroAPixel(index, vec4(
      exp(logMean + logSigma * gaussian(seed ^ 0x165667b1u)),
      exp(logMean + logSigma * gaussian(seed ^ 0x27d4eb2du)),
      exp(logMean + logSigma * gaussian(seed ^ 0x85ebca6bu)),
      1.0
    ));
    return;
  }

  if (params.operation == kOpMicroBlurX) {
    storeMicroBPixel(index, blurMicroX(gid3.xy));
    return;
  }

  if (params.operation == kOpMicroBlurY) {
    storeMicroAPixel(index, blurMicroY(gid3.xy));
    return;
  }

  if (params.operation == kOpResolveDensity) {
    const vec4 source = loadSourcePixel(index);
    if (u(kFrameIntGrainSublayersEnabled) == 0u) {
      storeDestinationPixel(index, vec4(
        max(grainLayerA[index * 9u], 0.0),
        max(grainLayerA[index * 9u + 1u], 0.0),
        max(grainLayerA[index * 9u + 2u], 0.0),
        source.a
      ));
      return;
    }
    const vec3 densityMin = vec3(channelDensityMin(0u), channelDensityMin(1u), channelDensityMin(2u));
    vec3 density = vec3(0.0);
    for (uint layer = 0u; layer < 3u; ++layer) {
      density.r += grainLayerA[index * 9u + layer * 3u];
      density.g += grainLayerA[index * 9u + layer * 3u + 1u];
      density.b += grainLayerA[index * 9u + layer * 3u + 2u];
    }
    density *= loadMicroAPixel(index).rgb;
    storeDestinationPixel(index, vec4(max(density - densityMin, vec3(0.0)), source.a));
    return;
  }

  if (params.operation == kOpSynthesisResolveDensity) {
    const vec4 source = loadSourcePixel(index);
    storeDestinationPixel(index, vec4(resolveGrainSynthesisDensity(index), source.a));
    return;
  }

  if (params.operation == kOpDensityBlurX) {
    storeDestinationPixel(index, densityBlurX(gid3.xy));
    return;
  }

  if (params.operation == kOpDensityBlurY) {
    storeDestinationPixel(index, densityBlurY(gid3.xy));
    return;
  }

  if (params.operation == kOpApplyControls) {
    const vec4 base = loadSourcePixel(index);
    const vec4 grained = loadDestinationPixel(index);
    storeAuxAPixel(index, vec4(applyGrainControls(base.rgb, grained.rgb), grained.a));
    return;
  }

  if (params.operation == kOpCopyDensity) {
    storeAuxAPixel(index, loadDestinationPixel(index));
  }
}
