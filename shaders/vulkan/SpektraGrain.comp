float gaussianWeight(float offset, float sigma) {
  return exp(-0.5 * (offset * offset) / max(sigma * sigma, 1.0e-8));
}

struct GaussianBlurInfo {
  float firstWeight;
  float firstRatio;
  float ratioStep;
  float invWeightSum;
  uint radius;
  uint enabled;
};

GaussianBlurInfo makeGaussianBlurInfo(float sigma, int radiusLimit) {
  GaussianBlurInfo info;
  info.firstWeight = 0.0;
  info.firstRatio = 0.0;
  info.ratioStep = 0.0;
  info.invWeightSum = 1.0;
  info.radius = 0u;
  info.enabled = sigma > 1.0e-4 ? 1u : 0u;
  if (info.enabled == 0u) {
    return info;
  }
  info.radius = uint(max(min(int(ceil(3.0 * sigma)), radiusLimit), 0));
  const float invSigma2 = 1.0 / max(sigma * sigma, 1.0e-8);
  info.firstWeight = exp(-0.5 * invSigma2);
  info.firstRatio = exp(-1.5 * invSigma2);
  info.ratioStep = exp(-invSigma2);
  float weight = info.firstWeight;
  float ratio = info.firstRatio;
  float weightSum = 1.0;
  for (uint offset = 1u; offset <= info.radius; ++offset) {
    weightSum += 2.0 * weight;
    weight *= ratio;
    ratio *= info.ratioStep;
  }
  info.invWeightSum = 1.0 / max(weightSum, 1.0e-8);
  return info;
}

float channelComponent(vec3 value, uint channel) {
  return value[int(channel)];
}

float channelDensityMin(uint channel) {
  if (channel == 0u) {
    return max(f(kFrameGrainDensityMinR), 0.0);
  }
  if (channel == 1u) {
    return max(f(kFrameGrainDensityMinG), 0.0);
  }
  return max(f(kFrameGrainDensityMinB), 0.0);
}

float channelParticleScale(uint channel) {
  if (channel == 0u) {
