  }
  if (channel == 1u) {
    return max(f(kFrameGrainParticleScaleG), 1.0e-3);
  }
  return max(f(kFrameGrainParticleScaleB), 1.0e-3);
}

float channelUniformity(uint channel) {
  if (channel == 0u) {
    return clamp(f(kFrameGrainUniformityR), 0.0, 1.0);
  }
  if (channel == 1u) {
    return clamp(f(kFrameGrainUniformityG), 0.0, 1.0);
  }
  return clamp(f(kFrameGrainUniformityB), 0.0, 1.0);
}

