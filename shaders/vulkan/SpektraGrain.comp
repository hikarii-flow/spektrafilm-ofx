uint u(uint index) {
  return frameInts[index];
}

uint spektraHash(uint x) {
  x ^= x >> 16u;
  x *= 0x7feb352du;
  x ^= x >> 15u;
  x *= 0x846ca68bu;
  x ^= x >> 16u;
  return x;
}

float rand01(uint seed) {
  return (float(spektraHash(seed) & 0x00ffffffu) + 0.5) / 16777216.0;
}

float gaussian(uint seed) {
  const float u1 = max(rand01(seed), 1.0e-6);
  const float u2 = rand01(seed ^ 0x9e3779b9u);
  return sqrt(-2.0 * log(u1)) * cos(6.28318530718 * u2);
}

uint filmCellSeed(vec2 filmUm, float cellSizeUm, uint seed) {
  const float safeCellSize = max(cellSizeUm, 1.0e-4);
  const ivec2 cell = ivec2(floor(filmUm / safeCellSize));
  return spektraHash(seed ^ (uint(cell.x) * 0x1f123bb5u) ^ (uint(cell.y) * 0x5f356495u));
}

uvec2 absolutePixel(uvec2 gid) {
  return gid + uvec2(params.tileOriginX, params.tileOriginY);
}

vec2 fullFrameDims() {
  return vec2(max(params.fullWidth, max(params.width, 1u)), max(params.fullHeight, max(params.height, 1u)));
}

vec2 outputPixelFilmUm(uvec2 gid) {
  const float scale = max(f(kFrameEnlargerScale), 1.0);
  const vec2 safeDims = fullFrameDims();
  const vec2 outputUv = (vec2(absolutePixel(gid)) + vec2(0.5)) / safeDims;
  const vec2 sourceUv = vec2(0.5) +
    (outputUv - vec2(0.5)) / scale +
    vec2(f(kFrameEnlargerOffsetXPercent), f(kFrameEnlargerOffsetYPercent)) * (0.01 / scale);
  const float framePixelSizeUm = max(f(kFrameFilmPixelSizeUm) * scale, 1.0e-6);
  return sourceUv * safeDims * framePixelSizeUm;
}

ivec2 filmUmToOutputPixel(vec2 filmUm) {
  const float scale = max(f(kFrameEnlargerScale), 1.0);
  const vec2 safeDims = fullFrameDims();
  const float framePixelSizeUm = max(f(kFrameFilmPixelSizeUm) * scale, 1.0e-6);
  const vec2 sourceUv = filmUm / (safeDims * framePixelSizeUm);
  const vec2 outputUv = vec2(0.5) +
    (sourceUv - vec2(0.5)) * scale -
    vec2(f(kFrameEnlargerOffsetXPercent), f(kFrameEnlargerOffsetYPercent)) * 0.01;
  return ivec2(floor(outputUv * safeDims)) - ivec2(params.tileOriginX, params.tileOriginY);
}

uint clampX(int x) {
  return uint(clamp(x, 0, int(max(params.width, 1u)) - 1));
}

uint clampY(int y) {
  return uint(clamp(y, 0, int(max(params.height, 1u)) - 1));
}

vec4 sampleSource(int x, int y) {
  const uint sx = clampX(x);
  const uint sy = clampY(y);
  return loadSourcePixel(sy * params.width + sx);
}

vec4 sampleDestination(int x, int y) {
  const uint sx = clampX(x);
  const uint sy = clampY(y);
  return loadDestinationPixel(sy * params.width + sx);
}

